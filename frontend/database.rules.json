{
  "rules": {
    "users": {
      ".read": "root.child('users').child(auth.uid).child('isAdmin').val() === true",
      "$uid": {
        ".read": "$uid === auth.uid || root.child('users').child(auth.uid).child('isAdmin').val() === true",
        ".write": "$uid === auth.uid || root.child('users').child(auth.uid).child('isAdmin').val() === true"
      }
    },
    "sessions": {
      ".read": "auth != null && query.orderByChild == 'uid' && query.equalTo == auth.uid",
      ".indexOn": ["uid"],
      
      "$sessionId": {
        ".read": "auth != null",
        ".write": "auth != null"
      }
    },
    "views": {
      ".read": "root.child('users').child(auth.uid).child('isAdmin').val() === true",
      "$viewId": {
        ".write": "auth != null && (!data.exists() || data.child('viewerUid').val() === auth.uid)"
      }
    },
    "app_config": {
      ".read": true,
      ".write": "auth != null && root.child('users').child(auth.uid).child('isAdmin').val() === true"
    },
    "subscriptions": {
      ".read": "auth != null && root.child('users').child(auth.uid).child('isAdmin').val() === true",
      ".write": true
    }
  }
}
